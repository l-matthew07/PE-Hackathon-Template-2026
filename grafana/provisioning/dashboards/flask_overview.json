    {
      "id": 7,
      "type": "timeseries",
      "transparent": true,
      "title": "Traffic \u2014 Request Rate by Status Code",
      "description": "2xx vs 4xx vs 5xx breakdown over time. Populates once Bronze wires http_requests_total.",
      "gridPos": {
        "x": 8,
        "y": 13,
        "w": 16,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
