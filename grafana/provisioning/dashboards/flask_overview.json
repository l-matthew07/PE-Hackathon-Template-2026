    {
      "id": 8,
      "type": "row",
      "title": "Infrastructure \u2014 Host Metrics",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 1
      },
      "collapsed": true,
      "panels": [
        {
          "id": 9,
          "type": "timeseries",
          "title": "CPU Usage %",
          "description": "Host CPU utilisation. Sustained > 80% is a saturation signal.",
          "gridPos": {
            "x": 0,
            "y": 1,
            "w": 12,
            "h": 8
          },
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
              "legendFormat": "CPU %",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "color": {
                "mode": "thresholds"
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "#00bcd4",
                    "value": null
                  },
                  {
                    "color": "#ff9800",
                    "value": 70
                  },
                  {
                    "color": "#e53935",
                    "value": 90
                  }
                ]
              },
              "custom": {
                "fillOpacity": 20,
                "gradientMode": "hue",
                "lineWidth": 2,
                "showPoints": "always",
                "pointSize": 4,
                "axisSoftMin": 0
              }
            }
          },
          "options": {
            "tooltip": {
              "mode": "single"
            }
          }
        },
        {
          "id": 10,
          "type": "timeseries",
          "title": "Memory Usage %",
          "description": "Host memory utilisation. Approaching 100% may cause OOM kills.",
          "gridPos": {
            "x": 12,
            "y": 1,
            "w": 12,
            "h": 8
          },
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
              "legendFormat": "Memory %",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "color": {
                "mode": "thresholds"
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "#00bcd4",
                    "value": null
                  },
                  {
                    "color": "#ff9800",
                    "value": 75
                  },
                  {
                    "color": "#e53935",
                    "value": 90
                  }
                ]
              },
              "custom": {
                "fillOpacity": 20,
                "gradientMode": "hue",
                "lineWidth": 2,
                "showPoints": "always",
                "pointSize": 4,
                "axisSoftMin": 0
