        },
        {
          "id": 11,
          "type": "timeseries",
          "title": "Disk I/O",
          "description": "Disk read/write throughput. A spike here during slow DB queries confirms I/O bottleneck.",
          "gridPos": {
            "x": 0,
            "y": 9,
            "w": 12,
            "h": 8
          },
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "rate(node_disk_read_bytes_total{device!~\"loop.*|nbd.*|ram.*|fd.*\"}[1m])",
              "legendFormat": "Read \u2014 {{ device }}",
              "refId": "A"
            },
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "rate(node_disk_written_bytes_total{device!~\"loop.*|nbd.*|ram.*|fd.*\"}[1m])",
              "legendFormat": "Write \u2014 {{ device }}",
              "refId": "B"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "Bps",
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "fillOpacity": 15,
                "gradientMode": "hue",
                "lineWidth": 2,
                "showPoints": "always",
                "pointSize": 3,
                "axisSoftMin": 0
              }
