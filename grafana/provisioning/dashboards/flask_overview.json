    },
    {
      "id": 5,
      "type": "timeseries",
      "transparent": true,
      "title": "URL Shortener \u2014 Redirect Hit Rate",
      "description": "Fraction of redirects that resolve vs 404. Populates once Bronze wires url_shortener_redirects_total.",
