{
  "uid": "flask-overview",
  "title": "Flask App \u2014 Incident Response Overview",
  "description": "4 Golden Signals + business metrics + host infrastructure + PostgreSQL + SLO error budget.",
  "tags": [
    "flask",
    "incident-response"
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "version": 20,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "graphTooltip": 2,
  "templating": {
    "list": [
      {
        "name": "endpoint",
        "type": "query",
        "label": "Endpoint",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(http_requests_total, endpoint)",
          "refId": "A"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {},
        "refresh": 2,
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 20,
      "type": "stat",
      "transparent": true,
      "title": "Service Health",
      "description": "Live now. Turns red the moment Prometheus can no longer scrape the Flask app.",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 5,
        "h": 2
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "up{job=\"flask_app\"}",
          "legendFormat": "Flask",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#e53935",
                "value": null
              },
              {
                "color": "#00bcd4",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "#e53935",
                  "index": 0
                },
                "1": {
                  "text": "UP",
                  "color": "#00bcd4",
                  "index": 1
                }
              }
            }
          ]
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 21,
      "type": "stat",
      "transparent": true,
      "title": "Error Rate %",
      "description": "5xx error rate over last 5 min. Populates once Bronze wires http_requests_total.",
      "gridPos": {
        "x": 5,
        "y": 1,
        "w": 5,
        "h": 2
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "job:flask_http_error_rate:rate5m * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#00bcd4",
                "value": null
              },
              {
                "color": "#ff9800",
                "value": 1
              },
              {
                "color": "#e53935",
                "value": 5
              }
            ]
          },
          "noValue": "Awaiting data"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 22,
      "type": "stat",
      "transparent": true,
      "title": "p95 Latency",
      "description": "95th percentile request duration. Populates once Bronze wires http_request_duration_seconds.",
      "gridPos": {
        "x": 10,
        "y": 1,
        "w": 5,
        "h": 2
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "job:flask_http_request_duration_p95:rate5m * 1000",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#00bcd4",
                "value": null
              },
              {
                "color": "#ff9800",
                "value": 200
              },
              {
                "color": "#e53935",
                "value": 500
              }
            ]
          },
          "noValue": "Awaiting data"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 23,
      "type": "stat",
      "transparent": true,
      "title": "CPU %",
      "description": "Host CPU utilisation from node_exporter. Live now.",
      "gridPos": {
        "x": 15,
        "y": 1,
        "w": 4,
        "h": 2
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#00bcd4",
                "value": null
              },
              {
                "color": "#ff9800",
                "value": 70
              },
              {
                "color": "#e53935",
                "value": 90
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 24,
      "type": "stat",
      "transparent": true,
      "title": "DB Connections",
      "description": "Live Postgres connections from postgres_exporter. Red at 20 = pool exhaustion.",
      "gridPos": {
        "x": 19,
        "y": 1,
        "w": 5,
        "h": 2
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(pg_stat_activity_count{datname=\"hackathon_db\"})",
          "legendFormat": "Connections",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#00bcd4",
                "value": null
              },
              {
                "color": "#ff9800",
                "value": 15
              },
              {
                "color": "#e53935",
                "value": 20
              }
            ]
          },
          "noValue": "No data"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 1,
      "type": "heatmap",
      "transparent": true,
      "title": "Latency \u2014 Distribution Heatmap",
      "description": "Latency bucket distribution over time. Brighter = more requests in that duration band. Shows distribution shifts instantly during incidents. Populates once Bronze wires http_request_duration_seconds.",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 14,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_request_duration_seconds_bucket[5m])) by (le)",
          "legendFormat": "{{ le }}",
          "format": "heatmap",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            }
          }
        },
        "overrides": []
      },
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "dark-blue",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "GnBu",
          "steps": 64
        },
        "exemplars": {
          "color": "rgba(255,0,255,0.7)"
        },
        "filterValues": {
          "le": 1e-09
        },
        "legend": {
          "show": true
        },
        "rowsFrame": {
          "layout": "auto"
        },
        "tooltip": {
          "mode": "single",
          "showColorScale": false,
          "yHistogram": true
        },
        "yAxis": {
          "axisPlacement": "left",
          "decimals": 3,
          "reverse": false,
          "unit": "s"
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "transparent": true,
      "title": "Traffic \u2014 Requests per Second",
      "description": "Incoming request rate by endpoint. Use the Endpoint dropdown to filter to a single route.",
      "gridPos": {
        "x": 14,
        "y": 3,
        "w": 10,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_requests_total{endpoint=~\"$endpoint\"}[2m])) by (endpoint)",
          "legendFormat": "{{ endpoint }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 20,
            "gradientMode": "hue",
            "lineWidth": 2,
            "showPoints": "always",
            "pointSize": 4,
            "axisSoftMin": 0
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "transparent": true,
      "title": "Errors \u2014 5xx Rate",
      "description": "Fraction of requests returning 5xx. Background turns red at 5%. Populates once Bronze wires http_requests_total.",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 10,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#00bcd4",
                "value": null
              },
              {
                "color": "#ff9800",
                "value": 0.01
              },
              {
                "color": "#e53935",
                "value": 0.05
              }
            ]
          },
          "noValue": "No data yet"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "transparent": true,
      "title": "Saturation \u2014 Active In-Flight Requests",
      "description": "Current number of requests being processed simultaneously. Populates once Bronze wires active_requests.",
