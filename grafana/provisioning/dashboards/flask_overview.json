        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(url_shortener_redirects_total{status=\"hit\"}[2m]) / rate(url_shortener_redirects_total[2m])",
          "legendFormat": "Hit Rate",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(url_shortener_redirects_total[2m])",
          "legendFormat": "{{ status }}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
