        "x": 10,
        "y": 8,
        "w": 7,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "active_requests",
          "legendFormat": "In-flight",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#00bcd4",
                "value": null
              },
              {
                "color": "#ff9800",
                "value": 50
              },
              {
                "color": "#e53935",
                "value": 80
              }
            ]
          },
          "noValue": "No data yet"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": false
